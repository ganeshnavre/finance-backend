datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique
  role  String
}

model Record {
  id       String @id @default(uuid())
  amount   Float
  type     String
  category String
}